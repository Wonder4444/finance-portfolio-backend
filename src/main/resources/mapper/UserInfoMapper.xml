<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wonder4.financeportfoliobackend.mapper.UserInfoMapper">

    <!-- 通用列 -->
    <sql id="baseColumns">
        id
        , user_name, email, base_currency, is_deleted, create_time, update_time
    </sql>

    <!-- XML: 根据 id 更新用户信息 (只更新非空字段) -->
    <update id="updateUserById">
        UPDATE user_info
        <set>
            <if test="entity.userName != null">user_name = #{entity.userName},</if>
            <if test="entity.email != null">email = #{entity.email},</if>
            <if test="entity.baseCurrency != null">base_currency = #{entity.baseCurrency},</if>
            update_time = NOW()
        </set>
        WHERE id = #{entity.id} AND is_deleted = 0
    </update>

    <!-- XML: 查询全部用户 (排除逻辑删除) -->
    <select id="selectAllUsers" resultType="com.wonder4.financeportfoliobackend.entity.UserInfo">
        SELECT
        <include refid="baseColumns"/>
        FROM user_info
        WHERE is_deleted = 0
        ORDER BY id ASC
    </select>

    <!-- XML: 分页查询用户 (MyBatis Plus 自动添加 LIMIT) -->
    <select id="selectUserPage" resultType="com.wonder4.financeportfoliobackend.entity.UserInfo">
        SELECT
        <include refid="baseColumns"/>
        FROM user_info
        WHERE is_deleted = 0
        ORDER BY id ASC
    </select>

</mapper>
